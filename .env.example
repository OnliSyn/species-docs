# Onli Synth Environment Variables

# Set to 'false' to connect to real APIs instead of local sims
NEXT_PUBLIC_USE_SIM=true

# MarketSB API (default: proxied to local sim on port 4001)
# NEXT_PUBLIC_MARKETSB_API_URL=https://marketsb.example.com/api/v1

# Species Marketplace API (default: proxied to local sim on port 4002)
# NEXT_PUBLIC_SPECIES_API_URL=https://species.example.com/marketplace/v1

# Onli Cloud API (default: proxied to local sim on port 4002)
# NEXT_PUBLIC_ONLI_CLOUD_API_URL=https://onli-cloud.example.com/marketplace/v1

# Anthropic API Key (enables real Claude AI in chat)
# ANTHROPIC_API_KEY=sk-ant-...
