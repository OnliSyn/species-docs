{
  "mcpServers": {
    "onli-marketsb-sim": {
      "command": "npm",
      "args": ["run", "start"],
      "cwd": "packages/marketsb-mcp",
      "env": {
        "MARKETSB_URL": "http://localhost:3101"
      }
    },
    "onli-species-sim": {
      "command": "npm",
      "args": ["run", "start"],
      "cwd": "packages/species-mcp",
      "env": {
        "SPECIES_URL": "http://localhost:3102"
      }
    }
  }
}
