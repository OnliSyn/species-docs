#!/bin/bash
export PATH="/opt/homebrew/opt/node/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:$PATH"
echo "🧪 Running test suite before push..."

# Build check
echo "📦 Build check..."
npx next build > /dev/null 2>&1
if [ $? -ne 0 ]; then
  echo "❌ BUILD FAILED — push blocked"
  exit 1
fi
echo "✅ Build passed"

# Full suite: Vitest global-setup starts sims when VITEST_MANAGE_SIMS=1 (npm run test)
echo "🔄 Running full test suite (sims auto-started or reused)..."
npm run test 2>&1
if [ $? -ne 0 ]; then
  echo "❌ TESTS FAILED — push blocked"
  exit 1
fi
echo "✅ All tests passed"

echo "🚀 Push approved"
