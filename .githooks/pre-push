#!/bin/bash
export PATH="/opt/homebrew/opt/node/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:$PATH"
echo "Running checks before push..."

# Build check
echo "Build check..."
node node_modules/next/dist/bin/next build > /dev/null 2>&1
if [ $? -ne 0 ]; then
  echo "BUILD FAILED — push blocked"
  exit 1
fi
echo "Build passed"

# Unit tests
echo "Running unit tests..."
node node_modules/vitest/vitest.mjs run 2>&1
if [ $? -ne 0 ]; then
  echo "TESTS FAILED — push blocked"
  exit 1
fi
echo "All tests passed"

echo "Push approved"
